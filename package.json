{
  "name": "smart-health-system",
  "version": "1.0.0",
  "description": "Smart Healthcare Queue Management System",
  "scripts": {
    "install-all": "cd smart_health/server && npm install && cd ../web && npm install",
    "dev": "concurrently \"cd smart_health/server && npm run dev\" \"cd smart_health/web && npm run dev\"",
    "build": "cd smart_health/web && npm run build",
    "start": "cd smart_health/server && npm start",
    "seed": "cd smart_health/server && npm run seed"
  },
  "keywords": ["healthcare", "queue-management", "react", "nodejs", "mongodb"],
  "author": "Prajwal",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}